<div class="col-span-12 md:col-span-7 card" style="display:flex;flex-direction:column;">
    <div class="card-head">
        <div style="display:flex;align-items:center;gap:8px;">
            <span class="material-symbols-outlined" style="font-size:14px;color:var(--amber);">movie</span>
            <span class="lbl">Cult Vault</span>
        </div>
        <span class="lbl">B-Horror Pick</span>
    </div>
    @if (!string.IsNullOrEmpty(Title))
    {
        <div style="flex:1;display:flex;gap:16px;padding:14px 16px;align-items:start;">
            @if (!string.IsNullOrEmpty(PosterUrl))
            {
                <img src="@PosterUrl" alt="@Title" style="width:72px;flex-shrink:0;object-fit:cover;border:1px solid var(--bord);" />
            }
            <div style="min-width:0;">
                <div class="font-display" style="font-size:17px;font-style:italic;font-weight:700;color:var(--amber);line-height:1.25;">@Title</div>
                <div class="lbl" style="margin-top:5px;letter-spacing:0.15em;">@Year</div>
                <div style="margin-top:10px;font-size:12px;line-height:1.6;color:var(--text);">@Why</div>
            </div>
        </div>
    }
    else
    {
        <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;">
            <span class="material-symbols-outlined" style="font-size:36px;color:var(--bord);">videocam_off</span>
            <span class="lbl">No signal</span>
        </div>
    }
</div>

@code {
    [Parameter] public string Title     { get; set; } = "";
    [Parameter] public string Year      { get; set; } = "";
    [Parameter] public string Why       { get; set; } = "";
    [Parameter] public string PosterUrl { get; set; } = "";
}
